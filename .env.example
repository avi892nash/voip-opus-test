# Copy to .env (gitignored) and adjust per environment.
# Used by both `web/` (Vite reads VITE_* at build time) and `server/` (FastAPI reads at runtime).

# --- Backend (server/) ---------------------------------------------------------------
PORT=8000

# Long random string. Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-change-me

JWT_ALGORITHM=HS256
JWT_EXPIRES_DAYS=7
DB_PATH=./data/voip.db

# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# --- Frontend (web/) -----------------------------------------------------------------
#
# VITE_API_URL / VITE_WS_URL are read by Vite at BUILD TIME and baked into
# the browser bundle. They tell the BROWSER where to reach the API.
#
#   - Leave UNSET for local dev (npm run dev / docker compose up):
#     the bundle uses relative URLs and goes through the Vite dev-server proxy.
#   - SET for production builds: e.g. when running `scripts/deploy-frontend.sh`.
#
# VITE_API_URL=https://api.example.com
# VITE_WS_URL=wss://api.example.com

# VITE_PROXY_TARGET tells the Vite DEV-SERVER (the Node process running
# `npm run dev`) where to forward /api and /ws requests. This is only read in
# dev — production builds ignore it.
#
# Defaults to VITE_API_URL if set, else to http://localhost:8000.
# In docker-compose this is overridden to `http://server:8000` so the proxy
# can reach the backend via the Docker service name.
# VITE_PROXY_TARGET=http://localhost:8000

# Optional TURN server for production (NAT traversal). STUN is hardcoded as a default.
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
