#!/bin/sh
# Maintainer script — runs before the .deb is removed.
# Stop + disable the service. Leave /var/lib/voip-opus (the SQLite DB) and
# /etc/voip-opus.env alone; the user can remove them manually if they want to
# fully purge.

set -e

if command -v systemctl >/dev/null 2>&1; then
    # Stop + disable both units that the package installs.
    for unit in voip-opus.service voip-opus-update.timer voip-opus-update.service; do
        if systemctl is-active --quiet "$unit"; then
            systemctl stop "$unit" || true
        fi
        if systemctl is-enabled --quiet "$unit" 2>/dev/null; then
            systemctl disable "$unit" || true
        fi
    done
fi

exit 0
