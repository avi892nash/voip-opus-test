# Configuration for the voip-opus systemd service.
# Edit then `systemctl restart voip-opus` to apply.
#
# This file is a dpkg conffile — your edits survive upgrades.

# Backend listens on this port (loopback only — Cloudflare Tunnel front-ends it).
PORT=8000

# JWT signing secret. Generated automatically on first install by the deb
# postinst (it replaces this placeholder with a fresh secrets.token_urlsafe(48)).
JWT_SECRET=REPLACE_ON_INSTALL

JWT_ALGORITHM=HS256
JWT_EXPIRES_DAYS=7

# SQLite file location — owned by the voip-opus system user.
DB_PATH=/var/lib/voip-opus/voip.db

# Where the built React PWA lives. The deb installs it here; do not change
# unless you know what you're doing.
WEB_DIST=/opt/voip-opus/web-dist

# CORS origins — comma-separated. This is the public hostname Cloudflare
# Tunnel routes to this Pi. Add more comma-separated if you serve from
# multiple domains. (Note: with the single-process deploy, everything is
# same-origin so CORS is rarely hit; we set it anyway as defense in depth.)
CORS_ORIGINS=https://voip.devshram.com

# Optional TURN server config baked into the frontend at build time. NOT
# read by the backend; documented here only for reference.
# VITE_TURN_URL=
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
